# Postbird configuration
PORT=5327
ADMIN_PASSWORD=change-me

# Public base URL of this install — tracking pixels, click redirects, confirm and
# unsubscribe links are all absolute URLs built from this. REQUIRED for real sends.
BASE_URL=https://mail.yourdomain.com

# Where the SQLite db + uploads live (defaults to ./data)
# DATA_DIR=/data

# HMAC secret for signed tokens (auto-generated into DATA_DIR/secret.key if unset)
# SECRET=

# Fallback SMTP (can also be configured in Settings UI, which takes precedence)
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
